# Docker Environment Configuration
PORT=10000
NODE_ENV=production

# Database (uses docker-compose service name)
MONGODB_URI=mongodb://mongo:27017/synchroedit

# JWT Configuration
# IMPORTANT: Change these secrets for production!
JWT_SECRET=your_docker_jwt_secret_here_change_me
JWT_CURRENT_KID=v1

# Generate your own RSA keys for production
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your_private_key_here
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEYS={"v1":"-----BEGIN PUBLIC KEY-----\nyour_public_key_here\n-----END PUBLIC KEY-----"}

# Security
DISABLE_SECURE_COOKIE=true

