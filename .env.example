# SyncroEdit uses Cloudflare Workers, D1, Durable Objects, and static assets.
# Runtime secrets should be configured with Wrangler, not committed to git.
#
# Local Worker development can use a .dev.vars file with:
# JWT_SECRET = "replace-with-a-long-random-local-secret"
#
# Production secret:
# wrangler secret put JWT_SECRET
# wrangler secret put RESEND_API_KEY
# wrangler secret put EMAIL_CODE_PEPPER
#
# Email verification:
# RESEND_API_KEY = "wrangler secret"
# EMAIL_CODE_PEPPER = "wrangler secret"
# EMAIL_FROM = "SyncroEdit <verify@yourdomain.com>"
# APP_NAME = "SyncroEdit"
#
# Optional comma-separated origins for non-same-origin development clients.
# Leave unset for production same-origin deployments.
# ALLOWED_ORIGINS = "http://localhost:8787"
