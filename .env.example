# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/synchroedit

# JWT Configuration
# IMPORTANT: Generate secure secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_CURRENT_KID=v1

# JWT RSA Keys (for production, generate your own keys)
# Generate with: ssh-keygen -t rsa -b 2048 -m PEM -f jwtRS256.key
# Then: openssl rsa -in jwtRS256.key -pubout -outform PEM -out jwtRS256.key.pub
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your_private_key_here
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEYS={"v1":"-----BEGIN PUBLIC KEY-----\nyour_public_key_here\n-----END PUBLIC KEY-----"}

# Security Configuration
DISABLE_SECURE_COOKIE=true

# Email Configuration (optional)
ENABLE_EMAIL_VERIFICATION=false
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# Frontend URL (used in password reset emails -- falls back to request host in dev)
# FRONTEND_URL=http://localhost:3000

# SMTP / Email delivery (optional -- see src/utils/email.js)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@example.com
# RESEND_API_KEY=re_xxxx   # Recommended over SMTP for cloud deployments

# Cloudflare Hybrid Migration - Durable Object Persistence Sync Bridge
# Toggles the internal POST endpoint /api/internal/documents/:documentId/yjs-state
DO_PERSISTENCE_SYNC_ENABLED=false
# Secret token used to authenticate requests from the Cloudflare Worker.
# DO_SYNC_SECRET=your_do_sync_secret_placeholder
