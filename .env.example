# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# For local development, this defaults to a local MongoDB instance.
MONGODB_URI=mongodb://localhost:27017/synchroedit

# JWT Configuration
# IMPORTANT: Generate secure secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production

# CSRF Configuration
# Required for production deployments.
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CSRF_SECRET=your_csrf_secret_here_change_in_production

# Security Configuration
# Set to true during local development to allow non-HTTPS cookie transmissions.
DISABLE_SECURE_COOKIE=true

# Email Configuration (optional)
# Toggle to true if you wish to verify email addresses during signup/login.
ENABLE_EMAIL_VERIFICATION=false

# SMTP / Email delivery (optional -- see src/utils/email.js)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@example.com
# RESEND_API_KEY=re_xxxx   # Recommended over SMTP for cloud deployments

# Frontend URL (used in password reset emails -- falls back to request host in dev)
# FRONTEND_URL=http://localhost:3000


