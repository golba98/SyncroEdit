{
  "name": "1-synchroedit",
  "version": "1.0.0",
  "description": "",
  "main": "src-worker/index.js",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "test": "npm run test:unit && npm run test:integration && npm run test:frontend",
    "test:unit": "cross-env SKIP_DB_SETUP=true jest tests/unit",
    "test:integration": "cross-env SKIP_DB_SETUP=true jest tests/integration",
    "test:frontend": "cross-env SKIP_DB_SETUP=true jest tests/frontend",
    "test:e2e": "playwright test --config=config/playwright.config.js",
    "lint": "eslint . --config config/eslint.config.cjs",
    "format": "prettier --write . --config config/.prettierrc --ignore-path config/.prettierignore"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "setupFiles": [
      "./tests/env.js"
    ],
    "testEnvironment": "node",
    "maxWorkers": 1,
    "moduleNameMapper": {
      "^/js/(.*)$": "<rootDir>/public/js/$1",
      "^y-websocket$": "<rootDir>/tests/mocks/emptyModule.js",
      "^y-quill$": "<rootDir>/tests/mocks/emptyModule.js",
      "^/vendor/idb-keyval/index\\.js$": "idb-keyval"
    },
    "transform": {
      "^.+\\.jsx?$": [
        "babel-jest",
        {
          "configFile": "./config/.babelrc"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/golba98-dev/SynchroEdit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/golba98-dev/SynchroEdit/issues"
  },
  "homepage": "https://github.com/golba98-dev/SynchroEdit#readme",
  "dependencies": {
    "hono": "^4.12.25",
    "idb-keyval": "^6.2.5",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@playwright/browser-chromium": "^1.61.0",
    "@playwright/test": "^1.59.1",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  }
}
